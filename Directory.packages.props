<Project>
    <PropertyGroup>
        <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
        <ShinyVersion>4.0.1</ShinyVersion>
    </PropertyGroup>
    <ItemGroup>
        <PackageVersion Include="Microsoft.Extensions.Localization" Version="10.0.5"/>
        <PackageVersion Include="Microsoft.Maui.Controls" Version="$(MauiVersion)"/>
        <PackageVersion Include="Microsoft.Maui.Controls.Maps" Version="$(MauiVersion)"/>
        <PackageVersion Include="Microsoft.Extensions.Logging.Debug" Version="10.0.5"
                        Condition="'$(Configuration)' == 'Debug'"/>
        <PackageVersion Include="CommunityToolkit.Mvvm" Version="8.4.2"/>
        <PackageVersion Include="Sentry.Maui" Version="6.3.2"/>
    </ItemGroup>
    <ItemGroup>
        <PackageVersion Include="Shiny.Extensions.Localization.Generator" Version="2.0.1"/>
        <PackageVersion Include="Shiny.Extensions.MauiHosting" Version="2.0.4"/>
        <PackageVersion Include="Shiny.Maui.Controls" Version="1.0.1-beta-0010"/>
        <PackageVersion Include="Shiny.Maui.Shell" Version="4.2.1"/>
        <PackageVersion Include="Shiny.Maui.Shell.UxDiversDialogs" Version="1.0.0"/>
        <PackageVersion Include="Shiny.Mediator.Maui" Version="6.2.1"/>
        <PackageVersion Include="Shiny.Mediator.Sentry" Version="6.2.1"/>
        <PackageVersion Include="Shiny.Locations" Version="$(ShinyVersion)"/>
        <PackageVersion Include="Shiny.Jobs" Version="$(ShinyVersion)"/>
        <PackageVersion Include="Shiny.Notifications" Version="$(ShinyVersion)"/>
        <PackageVersion Include="Shiny.DocumentDb.Sqlite" Version="3.2.0"/>
        <PackageVersion Include="Shiny.DocumentDb.Extensions.DependencyInjection" Version="3.2.0"/>
        <PackageVersion Include="Shiny.Reflector" Version="1.7.2"/>
    </ItemGroup>
    <ItemGroup>
        <PackageVersion Include="Shiny.Hosting.Maui" Version="$(ShinyVersion)"/>
        <PackageVersion Include="Shiny.Extensions.Configuration" Version="$(ShinyVersion)"/>
    </ItemGroup>
    <ItemGroup>
        <PackageVersion Include="Redth.MauiDevFlow.Agent" Version="0.23.1"/>
        <PackageVersion Include="coverlet.collector" Version="8.0.1"/>
        <PackageVersion Include="Microsoft.Extensions.TimeProvider.Testing" Version="10.4.0"/>
        <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="18.4.0"/>
        <PackageVersion Include="Imposter" Version="0.1.9"/>
        <PackageVersion Include="Shouldly" Version="4.3.0"/>
        <PackageVersion Include="TUnit" Version="1.34.5"/>
    </ItemGroup>
</Project>