<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shinyWonderland="clr-namespace:ShinyWonderland"
             x:Class="ShinyWonderland.AiLoadingPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             x:DataType="shinyWonderland:AiLoadingViewModel"
             BackgroundColor="Transparent">

    <Grid BackgroundColor="#CC000000">
        <Border StrokeThickness="0"
                MaximumWidthRequest="320"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Padding="40,48">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24" />
            </Border.StrokeShape>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Tertiary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource Primary}" Offset="0.5" />
                    <GradientStop Color="#7C3AED" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <VerticalStackLayout Spacing="24"
                                 HorizontalOptions="Center">

                <ActivityIndicator x:Name="Spinner"
                                   IsRunning="True"
                                   Color="White"
                                   HeightRequest="48"
                                   WidthRequest="48"
                                   HorizontalOptions="Center" />

                <Label x:Name="StatusLabel"
                       Text="Listening..."
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />

                <Button Text="Cancel"
                        BackgroundColor="#44FFFFFF"
                        TextColor="White"
                        CornerRadius="16"
                        FontAttributes="Bold"
                        HeightRequest="44"
                        WidthRequest="140"
                        HorizontalOptions="Center"
                        Command="{Binding Cancel}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
