<?xml version="1.0" encoding="utf-8"?>

<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:ShinyWonderland"
       x:Class="ShinyWonderland.AppShell"
       x:DataType="local:AppShell">

    <ShellItem Route="startup" FlyoutItemIsVisible="False">
        <ShellContent ContentTemplate="{DataTemplate local:StartupPage}" />
    </ShellItem>

    <TabBar Route="main">
        <Tab Icon="ride_time" Route="ridetimes" AutomationId="RideTimesTab">
            <ShellContent Title="{Binding Localize.RideTimes}"
                          ContentTemplate="{DataTemplate local:RideTimesPage}"/>
        </Tab>
        <Tab Icon="ride_time" Route="ridetimesmap" AutomationId="MapRideTimesTab">
            <ShellContent Title="{Binding Localize.RideTimes}"
                          ContentTemplate="{DataTemplate local:MapRideTimesPage}"/>
        </Tab>
        <Tab Icon="settings" Route="settings" AutomationId="SettingsTab">
            <ShellContent Title="{Binding Localize.Settings}"
                          ContentTemplate="{DataTemplate local:SettingsPage}"/>
        </Tab>
        <Tab Icon="parking" Route="parking" AutomationId="ParkingTab">
            <ShellContent Title="{Binding Localize.Parking}"
                          ContentTemplate="{DataTemplate local:ParkingPage}"/>
        </Tab>
        <Tab Icon="hours" Route="mealtimes" AutomationId="MealTimesTab">
            <ShellContent Title="{Binding Localize.MealTimes}"
                          ContentTemplate="{DataTemplate local:MealTimePage}"/>
        </Tab>
        <Tab Icon="hours" Route="hours" AutomationId="HoursTab">
            <ShellContent Title="{Binding Localize.Hours}"
                          ContentTemplate="{DataTemplate local:HoursPage}"/>
        </Tab>
    </TabBar>
</Shell>