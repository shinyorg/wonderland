<?xml version="1.0" encoding="utf-8"?>
<Border xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        x:Class="ShinyWonderland.Controls.ListItemView"
        Margin="16,6"
        Padding="0"
        Stroke="{AppThemeBinding Light=#10000000, Dark=#10FFFFFF}"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 16"
        BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
    <Border.Shadow>
        <Shadow Brush="{AppThemeBinding Light=#20000000, Dark=#40000000}"
                Offset="0,2"
                Radius="8"
                Opacity="1" />
    </Border.Shadow>
</Border>
