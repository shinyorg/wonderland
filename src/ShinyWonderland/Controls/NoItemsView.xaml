<?xml version="1.0" encoding="utf-8"?>
<VerticalStackLayout xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                     x:Class="ShinyWonderland.Controls.NoItemsView"
                     VerticalOptions="Center"
                     HorizontalOptions="Center"
                     Spacing="12"
                     Padding="40">

    <Border StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark=#2A2545}"
            HeightRequest="120"
            WidthRequest="120"
            HorizontalOptions="Center">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="60" />
        </Border.StrokeShape>
        <Image Source="shiny.png"
               HeightRequest="80"
               WidthRequest="80"
               Aspect="AspectFit"
               Opacity="0.7"
               HorizontalOptions="Center"
               VerticalOptions="Center" />
    </Border>

    <Label Text="Nothing here yet"
           FontSize="20"
           FontFamily="OpenSansSemibold"
           FontAttributes="Bold"
           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
           HorizontalOptions="Center"
           HorizontalTextAlignment="Center" />

    <Label Text="Check back soon for updates"
           FontSize="13"
           TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
           HorizontalOptions="Center"
           HorizontalTextAlignment="Center" />
</VerticalStackLayout>
