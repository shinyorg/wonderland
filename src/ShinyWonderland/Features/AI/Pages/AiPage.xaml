<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:ShinyWonderland.Features.AI.Pages"
             x:Class="ShinyWonderland.Features.AI.Pages.AiPage"
             x:DataType="pages:AiViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <Grid>
        <!-- Full-screen gradient backdrop -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
                <GradientStop Color="#08000F" Offset="0.0" />
                <GradientStop Color="#12062B" Offset="0.3" />
                <GradientStop Color="{StaticResource Tertiary}" Offset="0.7" />
                <GradientStop Color="{StaticResource Primary}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Ambient floating particles -->
        <BoxView x:Name="Particle1" Color="#A78BFA" Opacity="0.15"
                 WidthRequest="4" HeightRequest="4" CornerRadius="2"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 TranslationX="60" TranslationY="120" />
        <BoxView x:Name="Particle2" Color="#C4B5FD" Opacity="0.1"
                 WidthRequest="3" HeightRequest="3" CornerRadius="1.5"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 TranslationX="300" TranslationY="200" />
        <BoxView x:Name="Particle3" Color="#7C3AED" Opacity="0.2"
                 WidthRequest="5" HeightRequest="5" CornerRadius="2.5"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 TranslationX="180" TranslationY="80" />
        <BoxView x:Name="Particle4" Color="#A78BFA" Opacity="0.12"
                 WidthRequest="3" HeightRequest="3" CornerRadius="1.5"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 TranslationX="50" TranslationY="500" />
        <BoxView x:Name="Particle5" Color="#C4B5FD" Opacity="0.18"
                 WidthRequest="4" HeightRequest="4" CornerRadius="2"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 TranslationX="320" TranslationY="400" />
        <BoxView x:Name="Particle6" Color="#8B5CF6" Opacity="0.1"
                 WidthRequest="6" HeightRequest="6" CornerRadius="3"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 TranslationX="250" TranslationY="600" />

        <!-- Large background glow (phase-colored) -->
        <BoxView x:Name="BackgroundGlow"
                 Color="#7C3AED"
                 Opacity="0.12"
                 WidthRequest="350"
                 HeightRequest="350"
                 CornerRadius="175"
                 HorizontalOptions="Center"
                 VerticalOptions="Center"
                 Margin="0,0,0,60" />

        <!-- Main content -->
        <VerticalStackLayout Spacing="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Padding="40,0">

            <!-- Orb container -->
            <Grid HorizontalOptions="Center"
                  HeightRequest="200"
                  WidthRequest="200"
                  Margin="0,0,0,8">

                <!-- Ripple rings (Speaking phase - expand outward) -->
                <Border x:Name="Ripple1"
                        StrokeThickness="1.5"
                        Stroke="#A78BFA"
                        BackgroundColor="Transparent"
                        HeightRequest="90"
                        WidthRequest="90"
                        Opacity="0"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="45" />
                    </Border.StrokeShape>
                </Border>
                <Border x:Name="Ripple2"
                        StrokeThickness="1"
                        Stroke="#A78BFA"
                        BackgroundColor="Transparent"
                        HeightRequest="90"
                        WidthRequest="90"
                        Opacity="0"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="45" />
                    </Border.StrokeShape>
                </Border>
                <Border x:Name="Ripple3"
                        StrokeThickness="0.5"
                        Stroke="#A78BFA"
                        BackgroundColor="Transparent"
                        HeightRequest="90"
                        WidthRequest="90"
                        Opacity="0"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="45" />
                    </Border.StrokeShape>
                </Border>

                <!-- Outer pulse ring -->
                <Border x:Name="OuterRing"
                        StrokeThickness="1.5"
                        Stroke="#22FFFFFF"
                        BackgroundColor="Transparent"
                        HeightRequest="160"
                        WidthRequest="160"
                        Opacity="0.3"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="80" />
                    </Border.StrokeShape>
                </Border>

                <!-- Middle pulse ring -->
                <Border x:Name="MiddleRing"
                        StrokeThickness="1"
                        Stroke="#33FFFFFF"
                        BackgroundColor="Transparent"
                        HeightRequest="120"
                        WidthRequest="120"
                        Opacity="0.4"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="60" />
                    </Border.StrokeShape>
                </Border>

                <!-- Orbital dots (Thinking phase - rotate around orb) -->
                <Grid x:Name="OrbitalRing"
                      HeightRequest="140"
                      WidthRequest="140"
                      Opacity="0"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">
                    <BoxView x:Name="OrbitDot1"
                             Color="#A78BFA"
                             WidthRequest="8"
                             HeightRequest="8"
                             CornerRadius="4"
                             HorizontalOptions="Center"
                             VerticalOptions="Start" />
                    <BoxView x:Name="OrbitDot2"
                             Color="#C4B5FD"
                             WidthRequest="6"
                             HeightRequest="6"
                             CornerRadius="3"
                             HorizontalOptions="Start"
                             VerticalOptions="End"
                             Margin="20,0,0,15" />
                    <BoxView x:Name="OrbitDot3"
                             Color="#8B5CF6"
                             WidthRequest="7"
                             HeightRequest="7"
                             CornerRadius="3.5"
                             HorizontalOptions="End"
                             VerticalOptions="End"
                             Margin="0,0,20,15" />
                </Grid>

                <!-- Inner glowing orb (tappable) -->
                <Border x:Name="InnerOrb"
                        StrokeThickness="0"
                        HeightRequest="80"
                        WidthRequest="80"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        AutomationId="AiActivateOrb">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="40" />
                    </Border.StrokeShape>
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                            <GradientStop Color="#C4B5FD" Offset="0.0" />
                            <GradientStop Color="#8B5CF6" Offset="0.4" />
                            <GradientStop Color="{StaticResource Primary}" Offset="0.7" />
                            <GradientStop Color="{StaticResource Tertiary}" Offset="1.0" />
                        </RadialGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#7C3AED"
                                Offset="0,0"
                                Radius="40"
                                Opacity="0.7" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleAiCommand}" />
                    </Border.GestureRecognizers>

                    <!-- Phase icon (mic/brain/speaker) -->
                    <Label x:Name="PhaseIcon"
                           Text="&#x1F399;"
                           FontSize="28"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- Waveform bars (Listening phase) -->
            <HorizontalStackLayout x:Name="WaveformBars"
                                   HorizontalOptions="Center"
                                   Spacing="4"
                                   HeightRequest="40"
                                   Opacity="0"
                                   Margin="0,0,0,4">
                <BoxView x:Name="Bar1" Color="#8B5CF6" WidthRequest="4" HeightRequest="8"
                         CornerRadius="2" VerticalOptions="Center" />
                <BoxView x:Name="Bar2" Color="#A78BFA" WidthRequest="4" HeightRequest="8"
                         CornerRadius="2" VerticalOptions="Center" />
                <BoxView x:Name="Bar3" Color="#C4B5FD" WidthRequest="4" HeightRequest="8"
                         CornerRadius="2" VerticalOptions="Center" />
                <BoxView x:Name="Bar4" Color="#A78BFA" WidthRequest="4" HeightRequest="8"
                         CornerRadius="2" VerticalOptions="Center" />
                <BoxView x:Name="Bar5" Color="#8B5CF6" WidthRequest="4" HeightRequest="8"
                         CornerRadius="2" VerticalOptions="Center" />
                <BoxView x:Name="Bar6" Color="#C4B5FD" WidthRequest="4" HeightRequest="8"
                         CornerRadius="2" VerticalOptions="Center" />
                <BoxView x:Name="Bar7" Color="#A78BFA" WidthRequest="4" HeightRequest="8"
                         CornerRadius="2" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- Thinking dots (Thinking phase) -->
            <HorizontalStackLayout x:Name="ThinkingDots"
                                   HorizontalOptions="Center"
                                   Spacing="10"
                                   HeightRequest="40"
                                   Opacity="0"
                                   Margin="0,0,0,4">
                <BoxView x:Name="ThinkDot1" Color="#A78BFA"
                         WidthRequest="10" HeightRequest="10" CornerRadius="5"
                         VerticalOptions="Center" Opacity="0.3" />
                <BoxView x:Name="ThinkDot2" Color="#A78BFA"
                         WidthRequest="10" HeightRequest="10" CornerRadius="5"
                         VerticalOptions="Center" Opacity="0.3" />
                <BoxView x:Name="ThinkDot3" Color="#A78BFA"
                         WidthRequest="10" HeightRequest="10" CornerRadius="5"
                         VerticalOptions="Center" Opacity="0.3" />
            </HorizontalStackLayout>

            <!-- Status text -->
            <Label x:Name="StatusLabel"
                   Text="Tap to Ask"
                   FontSize="17"
                   FontFamily="OpenSansSemibold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,4,0,4" />

            <!-- Subtitle -->
            <Label x:Name="SubtitleLabel"
                   Text="Powered by AI"
                   FontSize="13"
                   FontFamily="OpenSansRegular"
                   TextColor="#8B7FB5"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
