<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shinyWonderland="clr-namespace:ShinyWonderland.Features.Rides.Pages"
             xmlns:controls="clr-namespace:ShinyWonderland.Controls"
             x:DataType="shinyWonderland:RideHistoryViewModel"
             x:Class="ShinyWonderland.Features.Rides.Pages.RideHistoryPage"
             AutomationId="RideHistoryPage"
             Title="{Binding Localize.Title}">

    <CollectionView ItemsSource="{Binding History}"
                    AutomationId="RideHistoryCollectionView"
                    Margin="0,8,0,0">
        <CollectionView.EmptyView>
            <controls:NoItemsView />
        </CollectionView.EmptyView>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="shinyWonderland:RideHistoryItemViewModel">
                <controls:ListItemView>
                    <Grid ColumnDefinitions="4, *"
                          Padding="0">
                        <BoxView Grid.Column="0"
                                 Color="{StaticResource RideAccent}"
                                 CornerRadius="0"
                                 VerticalOptions="Fill" />
                        <VerticalStackLayout Grid.Column="1"
                                             Padding="16,14"
                                             Spacing="4">
                            <Label Text="{Binding RideName}"
                                   FontSize="16"
                                   FontFamily="OpenSansSemibold"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                            <Label Text="{Binding TimeAgo}"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
                        </VerticalStackLayout>
                    </Grid>
                </controls:ListItemView>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
