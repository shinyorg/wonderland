<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shinyWonderland="clr-namespace:ShinyWonderland"
             xmlns:controls="clr-namespace:ShinyWonderland.Controls"
             x:DataType="shinyWonderland:MealTimeViewModel"
             x:Class="ShinyWonderland.MealTimePage"
             AutomationId="MealTimePage"
             Title="{Binding Localize.Title}">
    <Grid RowDefinitions="Auto, Auto, *" Padding="10">

        <!-- Drink Section -->
        <VerticalStackLayout Grid.Row="0" Spacing="5" Padding="5">
            <Label Text="Drink Passes" FontAttributes="Bold" HorizontalOptions="Center" />
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Button Text="-"
                        AutomationId="RemoveDrinkPassButton"
                        Command="{Binding RemoveDrinkPassCommand}"
                        WidthRequest="44" />
                <Label Text="{Binding DrinkPassCount}"
                       VerticalOptions="Center"
                       AutomationId="DrinkPassCountLabel"
                       FontSize="18" />
                <Button Text="+"
                        AutomationId="AddDrinkPassButton"
                        Command="{Binding AddDrinkPassCommand}"
                        WidthRequest="44" />
            </HorizontalStackLayout>
            <Button Text="{Binding DrinkButtonText}"
                    AutomationId="DrinkPassButton"
                    Command="{Binding UseDrinkPassCommand}"
                    IsEnabled="{Binding IsDrinkAvailable}"
                    HorizontalOptions="Fill" />
        </VerticalStackLayout>

        <!-- Food Section -->
        <VerticalStackLayout Grid.Row="1" Spacing="5" Padding="5">
            <Label Text="Food Passes" FontAttributes="Bold" HorizontalOptions="Center" />
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Button Text="-"
                        AutomationId="RemoveFoodPassButton"
                        Command="{Binding RemoveFoodPassCommand}"
                        WidthRequest="44" />
                <Label Text="{Binding FoodPassCount}"
                       VerticalOptions="Center"
                       AutomationId="FoodPassCountLabel"
                       FontSize="18" />
                <Button Text="+"
                        AutomationId="AddFoodPassButton"
                        Command="{Binding AddFoodPassCommand}"
                        WidthRequest="44" />
            </HorizontalStackLayout>
            <Button Text="{Binding FoodButtonText}"
                    AutomationId="FoodPassButton"
                    Command="{Binding UseFoodPassCommand}"
                    IsEnabled="{Binding IsFoodAvailable}"
                    HorizontalOptions="Fill" />
        </VerticalStackLayout>

        <!-- History -->
        <CollectionView AutomationId="MealHistoryCollectionView"
                        ItemsSource="{Binding History}"
                        Grid.Row="2">
            <CollectionView.EmptyView>
                <controls:NoItemsView />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="shinyWonderland:MealTimeHistoryRecord">
                    <HorizontalStackLayout Padding="10" Spacing="10">
                        <Label Text="{Binding Type}" VerticalOptions="Center" />
                        <Label Text="{Binding Timestamp, StringFormat='{0:g}'}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
