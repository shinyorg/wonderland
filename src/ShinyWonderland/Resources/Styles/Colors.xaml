<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand -->
    <Color x:Key="Primary">#6C3AE0</Color>
    <Color x:Key="PrimaryDark">#5228B8</Color>
    <Color x:Key="PrimaryLight">#A78BFA</Color>
    <Color x:Key="Secondary">#EDE9FE</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <!-- Surfaces -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceDark">#1E1E2E</Color>
    <Color x:Key="CardLight">#FFFFFF</Color>
    <Color x:Key="CardDark">#2A2A3D</Color>
    <Color x:Key="PageLight">#F4F1FB</Color>
    <Color x:Key="PageDark">#121220</Color>

    <!-- Grays -->
    <Color x:Key="Gray100">#F1F0F5</Color>
    <Color x:Key="Gray200">#E2E0EA</Color>
    <Color x:Key="Gray300">#B8B5C5</Color>
    <Color x:Key="Gray400">#908DA0</Color>
    <Color x:Key="Gray500">#6B687D</Color>
    <Color x:Key="Gray600">#49475A</Color>
    <Color x:Key="Gray900">#1E1E2E</Color>
    <Color x:Key="Gray950">#13131F</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="SuccessLight">#DCFCE7</Color>
    <Color x:Key="SuccessDark">#166534</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="WarningLight">#FEF3C7</Color>
    <Color x:Key="WarningDark">#92400E</Color>
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="DangerLight">#FEE2E2</Color>
    <Color x:Key="DangerDark">#991B1B</Color>
    <Color x:Key="Info">#3B82F6</Color>
    <Color x:Key="InfoLight">#DBEAFE</Color>
    <Color x:Key="InfoDark">#1E40AF</Color>

    <!-- Feature Accents -->
    <Color x:Key="RideAccent">#8B5CF6</Color>
    <Color x:Key="WaitLow">#22C55E</Color>
    <Color x:Key="WaitMedium">#F59E0B</Color>
    <Color x:Key="WaitHigh">#EF4444</Color>
    <Color x:Key="MealDrink">#06B6D4</Color>
    <Color x:Key="MealFood">#F97316</Color>
    <Color x:Key="ParkingAccent">#10B981</Color>

    <!-- Legacy compat -->
    <Color x:Key="Yellow100Accent">#F59E0B</Color>
    <Color x:Key="Yellow200Accent">#FCD34D</Color>
    <Color x:Key="Yellow300Accent">#FDE68A</Color>
    <Color x:Key="Cyan100Accent">#06B6D4</Color>
    <Color x:Key="Cyan200Accent">#67E8F9</Color>
    <Color x:Key="Cyan300Accent">#CFFAFE</Color>
    <Color x:Key="Blue100Accent">#3B82F6</Color>
    <Color x:Key="Blue200Accent">#93C5FD</Color>
    <Color x:Key="Blue300Accent">#BFDBFE</Color>
    <Color x:Key="DarkRed">#991B1B</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
    <SolidColorBrush x:Key="DarkRedBrush" Color="{StaticResource DarkRed}"/>
</ResourceDictionary>
