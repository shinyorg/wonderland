<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>

        <TargetFrameworks>$(BaseTargetFramework)-ios;$(BaseTargetFramework)-android</TargetFrameworks>
<!--        <TargetFrameworks>$(TargetFrameworks);$(BaseTargetFramework)</TargetFrameworks>-->
        <RootNamespace>ShinyWonderland</RootNamespace>
        <SingleProject>true</SingleProject>
        <LangVersion>preview</LangVersion>

        <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>
        <MauiXamlInflator>SourceGen</MauiXamlInflator>
        <ShinyMediatorGenerateAITools>true</ShinyMediatorGenerateAITools>
        <ShinyMauiShell_GenerateAiExtensions>true</ShinyMauiShell_GenerateAiExtensions>

        <ApplicationTitle>Wonderland</ApplicationTitle>
        <ApplicationId>org.shiny.wonderland</ApplicationId>
        <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
        <ApplicationVersion>1</ApplicationVersion>
    </PropertyGroup>

    <PropertyGroup Condition="'$(TargetFramework)' != '$(BaseTargetFramework)'">
        <OutputType>Exe</OutputType>
        <UseMaui>true</UseMaui>
        <DefineConstants>$(DefineConstants);PLATFORM</DefineConstants>
    </PropertyGroup>

    <PropertyGroup Condition="'$(TargetFramework)' == '$(BaseTargetFramework)'">
        <OutputType>Library</OutputType>
        <UseMaui>false</UseMaui>
    </PropertyGroup>

    <PropertyGroup Condition="'$(CI)' == 'true' AND '$(Configuration)' == 'Release'">
        <SentryOrg>shiny-software</SentryOrg>
        <SentryProject>wonderland</SentryProject>

        <SentryCreateRelease>false</SentryCreateRelease>
        <SentrySetCommits>false</SentrySetCommits>
        <SentryUploadSymbols>true</SentryUploadSymbols>
        <SentryUploadSources>true</SentryUploadSources>
        <SentryUploadAndroidProguardMapping>true</SentryUploadAndroidProguardMapping>
    </PropertyGroup>

    <PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">
        <DefineConstants>$(DefineConstants);PLATFORM</DefineConstants>
        <SupportedOSPlatformVersion>26.0</SupportedOSPlatformVersion>
        <TargetPlatformVersion>36</TargetPlatformVersion>
        <AndroidEnableMarshalMethods>false</AndroidEnableMarshalMethods>
    </PropertyGroup>

    <PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">
        <IsAotCompatible>true</IsAotCompatible>
        <PublishAot>true</PublishAot>
        <SupportedOSPlatformVersion>15.0</SupportedOSPlatformVersion>
        <DefineConstants>$(DefineConstants);APPLE;PLATFORM</DefineConstants>
    </PropertyGroup>

    <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">
        <BundleResource Include="Platforms\iOS\PrivacyInfo.xcprivacy" LogicalName="PrivacyInfo.xcprivacy"/>

        <CustomEntitlements Include="keychain-access-groups" Type="StringArray" Value="%24(AppIdentifierPrefix)$(ApplicationId)" Visible="false"/>
    </ItemGroup>

    <ItemGroup>
        <MauiIcon Include="Resources\AppIcon\appicon.png" ForegroundFile="Resources\AppIcon\appiconfg.png" Color="#512BD4"/>
        <MauiSplashScreen Include="Resources\Splash\splash.png" Color="#512BD4" BaseSize="128,128"/>

        <MauiImage Include="Resources\Images\*"/>
        <MauiFont Include="Resources\Fonts\*"/>
        <MauiAsset Include="Resources\Raw\**" LogicalName="%(RecursiveDir)%(Filename)%(Extension)"/>
        <MauiAsset Include="appsettings.json" LogicalName="appsettings.json"/>

        <Content Remove="**\appsettings.json"/>
        <Content Remove="**\appsettings.*.json"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Maui.Controls"/>
        <PackageReference Include="Microsoft.Maui.Controls.Maps"/>
        <PackageReference Include="CommunityToolkit.Mvvm"/>
        <PackageReference Include="Sentry.Maui"/>
        <PackageReference Include="Shiny.Extensions.MauiHosting"/>
        <PackageReference Include="Shiny.Extensions.Reactive"/>
        <PackageReference Include="Shiny.Maui.Shell"/>
        <PackageReference Include="Shiny.Maui.Shell.UxDiversDialogs"/>
        <PackageReference Include="Shiny.Maui.Controls"/>
        <PackageReference Include="Shiny.Mediator.Maui"/>
        <PackageReference Include="Shiny.Mediator.Sentry"/>
        <PackageReference Include="Shiny.Locations"/>
        <PackageReference Include="Shiny.Jobs"/>
        <PackageReference Include="Shiny.Notifications"/>
        <PackageReference Include="Shiny.DocumentDb.Sqlite"/>
        <PackageReference Include="Shiny.DocumentDb.Extensions.DependencyInjection"/>
        <PackageReference Include="Shiny.AiConversation"/>
        <PackageReference Include="Shiny.AiConversation.Maui.GithubCopilot"/>
    </ItemGroup>

    <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) != ''">
        <PackageReference Include="Shiny.Hosting.Maui"/>
        <PackageReference Include="Shiny.Extensions.Configuration"/>
    </ItemGroup>

    <ItemGroup Condition="'$(Configuration)' == 'Debug'">
        <PackageReference Include="Microsoft.Maui.DevFlow.Agent"/>
        <PackageReference Include="Microsoft.Extensions.Logging.Debug"/>
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="ShinyWonderland.Tests"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\ShinyWonderland.ApiClient\ShinyWonderland.ApiClient.csproj"/>
        <ProjectReference Include="..\ShinyWonderland.Localization\ShinyWonderland.Localization.csproj"/>
    </ItemGroup>
</Project>